cd medication-delivery
cat > .gitignore << 'EOF'
# Dependencies
node_modules/
.npm

# Environment variables — never commit these
.env
.env.local
.env.production

# Build outputs
dist/
build/

# Prisma
prisma/migrations/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
EOF

# Terraform
infrastructure/terraform/terraform.tfvars
infrastructure/terraform/.terraform/
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.backup
